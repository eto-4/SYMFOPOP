{% extends 'base.html.twig' %}

{% block pageTitle %}Iniciar sessió — SymfoPop{% endblock %}
{% block title %}Login{% endblock %}

{% block body %}

<div class="auth-wrapper">
    <div class="auth-card">

        <h1 class="fw-semibold mb-1 text-center">Benvingut de nou</h1>
        <p class="text-muted text-center small mb-4">Inicia sessió per gestionar els teus productes.</p>

        {% if error %}
            <div class="alert alert-danger">
                {{ error.messageKey|trans(error.messageData, 'security') }}
            </div>
        {% endif %}

        <form method="post">
            <div class="mb-3">
                <label for="username" class="form-label fw-semibold">Correu electrònic</label>
                <input type="email"
                       id="username"
                       name="_username"
                       value="{{ last_username }}"
                       class="form-control"
                       autocomplete="email"
                       required
                       autofocus>
            </div>

            <div class="mb-3">
                <label for="password" class="form-label fw-semibold">Contrasenya</label>
                <input type="password"
                       id="password"
                       name="_password"
                       class="form-control"
                       autocomplete="current-password"
                       required>
            </div>

            <div class="mb-4 d-flex align-items-center gap-2">
                <input type="checkbox" name="_remember_me" id="remember_me" checked>
                <label for="remember_me" class="small text-muted">Manten-me connectat</label>
            </div>

            <input type="hidden" name="_csrf_token" value="{{ csrf_token('authenticate') }}">

            <button type="submit" class="btn btn-primary w-100 mb-3">
                Iniciar sessió
            </button>

            <p class="text-center small text-muted mb-0">
                Encara no tens compte?
                <a href="{{ path('app_register') }}">Registra't</a>
            </p>
        </form>

    </div>
</div>

{% endblock %}
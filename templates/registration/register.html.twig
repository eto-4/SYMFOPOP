{% extends 'base.html.twig' %}

{% block pageTitle %}Registre — SymfoPop{% endblock %}

{% block body %}

<div class="auth-wrapper">
    <div class="auth-card">

        <h1 class="fw-semibold mb-1 text-center">Crea el teu compte</h1>
        <p class="text-muted text-center small mb-4">Uneix-te a SymfoPop i publica els teus productes.</p>

        {{ form_errors(registrationForm) }}

        {{ form_start(registrationForm, { attr: { novalidate: 'novalidate' } }) }}

            {{ form_row(registrationForm.name, { label: 'Nom', label_attr: { class: 'fw-semibold' } }) }}
            {{ form_row(registrationForm.email, { label: 'Correu electrònic', label_attr: { class: 'fw-semibold' } }) }}
            {{ form_row(registrationForm.plainPassword, { label: 'Contrasenya', label_attr: { class: 'fw-semibold' } }) }}
            {{ form_row(registrationForm.agreeTerms, { label: 'Accepto els termes i condicions', label_attr: { class: 'small text-muted' } }) }}

            <button type="submit" class="btn btn-primary w-100 mb-3">
                Crear compte
            </button>

            <p class="text-center small text-muted mb-0">
                Ja tens compte?
                <a href="{{ path('app_login') }}">Inicia sessió</a>
            </p>

        {{ form_end(registrationForm) }}

    </div>
</div>

{% endblock %}
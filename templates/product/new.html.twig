{% extends 'base.html.twig' %}

{% block pageTitle %}Nou producte — SymfoPop{% endblock %}
{% block title %}Nou producte{% endblock %}

{% block body %}

<div class="container">
    <div class="row justify-content-center">
        <div class="col-lg-7">

            <div class="card border-0 shadow-sm p-4">
                <h1 class="fw-semibold mb-1">Nou producte</h1>
                <p class="text-muted small mb-4">Omple el formulari per publicar el teu producte.</p>

                {{ form_start(form, { attr: { novalidate: 'novalidate' } }) }}

                    <div class="mb-3">
                        {{ form_label(form.name, 'Títol', { label_attr: { class: 'form-label fw-semibold' } }) }}
                        {{ form_widget(form.name, { attr: { class: 'form-control' } }) }}
                        {{ form_errors(form.name) }}
                    </div>

                    <div class="mb-3">
                        {{ form_label(form.description, 'Descripció', { label_attr: { class: 'form-label fw-semibold' } }) }}
                        {{ form_widget(form.description, { attr: { class: 'form-control', rows: 4 } }) }}
                        {{ form_errors(form.description) }}
                    </div>

                    <div class="mb-3">
                        {{ form_label(form.price, 'Preu (€)', { label_attr: { class: 'form-label fw-semibold' } }) }}
                        {{ form_widget(form.price, { attr: { class: 'form-control' } }) }}
                        {{ form_errors(form.price) }}
                    </div>

                    <div class="mb-4">
                        {{ form_label(form.image, 'URL de la imatge (opcional)', { label_attr: { class: 'form-label fw-semibold' } }) }}
                        {{ form_widget(form.image, { attr: { class: 'form-control', placeholder: 'https://...' } }) }}
                        {{ form_errors(form.image) }}
                        <div class="form-text">Si no poses imatge, en generarem una automàticament.</div>
                    </div>

                    <div class="d-flex gap-2">
                        <button type="submit" class="btn btn-primary">
                            Crear producte
                        </button>
                        <a href="{{ path('app_product_index') }}" class="btn btn-outline-secondary">
                            Cancel·lar
                        </a>
                    </div>

                {{ form_end(form) }}
            </div>

        </div>
    </div>
</div>

{% endblock %}
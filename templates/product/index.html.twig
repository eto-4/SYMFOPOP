{% extends 'base.html.twig' %}

{% block pageTitle %}{{ title|default('Productes') }} — SymfoPop{% endblock %}
{% block title %}{{ title|default('Productes') }}{% endblock %}

{% block body %}

<div class="container">

    {# Header de secció #}
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h1 class="fw-semibold mb-1">{{ title|default('Productes') }}</h1>
            <p class="text-muted small mb-0">
                {{ products|length }} producte{{ products|length != 1 ? 's' : '' }} disponible{{ products|length != 1 ? 's' : '' }}
            </p>
        </div>

        {# Botó "Nou producte" — només a "Els meus productes" #}
        {% if show_new_button|default(false) %}
            <a href="{{ path('app_product_new') }}" class="btn btn-primary">
                + Nou producte
            </a>
        {% endif %}
    </div>

    <div class="row g-4">

        {% for product in products %}
            <div class="col-sm-6 col-lg-4">
                <div class="product-card card">

                    {# Imatge #}
                    {% if product.image %}
                        <img src="{{ product.image }}"
                             class="card-img-top"
                             alt="{{ product.name }}"
                             style="height: 200px; object-fit: cover;">
                    {% endif %}

                    <div class="card-body d-flex flex-column">

                        {# Títol #}
                        <h5 class="card-title mb-2">
                            <a href="{{ path('app_product_show', { id: product.id }) }}">
                                {{ product.name }}
                            </a>
                        </h5>

                        {# Descripció curta #}
                        <p class="text-muted small mb-3">
                            {{ product.description|length > 110
                                ? product.description|slice(0, 110) ~ '...'
                                : product.description }}
                        </p>

                        {# Autor i data #}
                        <div class="d-flex align-items-center gap-2 mb-3">
                            <div class="avatar-placeholder">
                                {{ product.owner.name|first|upper }}
                            </div>
                            <div class="small text-muted">
                                {{ product.owner.name }}<br>
                                {{ product.createdAt|date('d/m/Y') }}
                            </div>
                        </div>

                        {# Preu + botons #}
                        <div class="mt-auto">
                            <div class="d-flex justify-content-between align-items-center mb-3">
                                <span class="fw-bold text-primary fs-5">
                                    {{ product.price|number_format(2, ',', '.') }} €
                                </span>
                            </div>

                            <a href="{{ path('app_product_show', { id: product.id }) }}"
                               class="btn btn-outline-primary w-100 mb-2">
                                Veure detall
                            </a>

                            {# Botons d'acció — només a "Els meus productes" #}
                            {% if show_actions|default(false) %}
                                <div class="d-flex gap-2">
                                    <a href="{{ path('app_product_edit', { id: product.id }) }}"
                                       class="btn btn-sm btn-outline-secondary flex-fill">
                                        ✏️ Editar
                                    </a>
                                    <form method="post"
                                          action="{{ path('app_product_delete', { id: product.id }) }}"
                                          onsubmit="return confirm('Segur que vols eliminar aquest producte?');"
                                          class="flex-fill">
                                        <input type="hidden" name="_token"
                                               value="{{ csrf_token('delete' ~ product.id) }}">
                                        <button class="btn btn-sm btn-outline-danger w-100">
                                            🗑️ Eliminar
                                        </button>
                                    </form>
                                </div>
                            {% endif %}

                        </div>
                    </div>
                </div>
            </div>

        {% else %}

            <div class="col-12 text-center py-5">
                <p class="text-muted">
                    {{ empty_message|default('No hi ha productes disponibles.') }}
                </p>
                {% if show_new_button|default(false) %}
                    <a href="{{ path('app_product_new') }}" class="btn btn-primary mt-2">
                        Publica el teu primer producte
                    </a>
                {% endif %}
            </div>

        {% endfor %}

    </div>
</div>

{% endblock %}